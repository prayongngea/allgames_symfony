<div class="p-4 md:w-1/3 sm:mb-0 mb-6">
    <div class="rounded-lg h-64 overflow-hidden bg-gray-800">
        {% if game.imageName %}
            <img alt="{{ game.name }}" class="object-cover object-center h-full w-full"
                src="{{ vich_uploader_asset(game, 'imageFile') }}">
        {% else %}
            <div class="w-full h-full flex items-center justify-center bg-gray-700">
                <div class="text-center text-gray-500">
                    <div class="text-5xl mb-2">🎮</div>
                    <p class="text-sm">Pas d'image</p>
                </div>
            </div>
        {% endif %}
    </div>
    <h2 class="text-xl font-medium title-font text-white mt-5">{{ game.name }}</h2>
    {% if game.description %}
        <p class="text-base leading-relaxed mt-2">{{ game.description|striptags|slice(0, 100) }}...</p>
    {% endif %}
    <a class="text-blue-400 inline-flex items-center mt-3 hover:text-blue-300" href="{{ path('app_game_show', {'id': game.id}) }}">
        Voir plus
        <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="w-4 h-4 ml-2" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
    </a>
</div>
