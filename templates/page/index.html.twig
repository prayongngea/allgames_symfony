{% extends 'base.html.twig' %}

{% block title %}AllGames - Wishlist all your favorite games{% endblock %}

{% block body %}
<section class="text-gray-400 bg-gray-900 body-font">
    <div class="container mx-auto flex px-5 py-24 md:flex-row flex-col items-center">
        <div class="lg:flex-grow md:w-1/2 lg:pr-24 md:pr-16 flex flex-col md:items-start md:text-left mb-16 md:mb-0 items-center text-center">
            <h1 class="title-font sm:text-4xl text-3xl mb-4 font-medium text-white">Wishlist all your favorite games</h1>
            <p class="mb-8 leading-relaxed">Keep track of the games you love, stay informed about new releases, and never miss a deal. Build a wishlist of must-play titles in one place.</p>
            <div class="flex justify-center">
                <a href="{{ path('app_game_list') }}" class="inline-flex text-white bg-blue-500 border-0 py-2 px-6 focus:outline-none hover:bg-blue-600 rounded text-lg">View all games</a>
            </div>
        </div>
        <div class="lg:max-w-lg lg:w-full md:w-1/2 w-5/6 flex items-center justify-center">
            <div class="text-center">
                <div class="text-9xl mb-4">🎮</div>
                <p class="text-4xl font-bold text-white"><span class="text-blue-500">All</span>Games</p>
            </div>
        </div>
    </div>
</section>

{% if games|length > 0 %}
<section class="text-gray-400 bg-gray-900 body-font">
    <div class="container px-5 py-24 mx-auto">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">Derniers Jeux</h2>
        <div class="flex flex-wrap sm:-m-4 -mx-4 -mb-10 -mt-4">
            {% for game in games %}
                {% include 'game/_game_item.html.twig' with {'game': game} %}
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}
{% endblock %}
