<div id="wishlist-button-{{ game.id }}">
    {% if is_in_wishlist %}
        <form action="{{ path('app_game_wishlist_toggle', { id: game.id }) }}" method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('wishlist' ~ game.id) }}">
            <button type="submit" class="flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-6 rounded-lg transition">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/></svg>
                Retirer de la liste
            </button>
        </form>
    {% elseif app.user %}
        <form action="{{ path('app_game_wishlist_toggle', { id: game.id }) }}" method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('wishlist' ~ game.id) }}">
            <button type="submit" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                Ajouter à ma liste
            </button>
        </form>
    {% else %}
        <a href="{{ path('app_login') }}" class="flex items-center gap-2 bg-gray-700 hover:bg-gray-600 text-white font-bold py-2 px-6 rounded-lg transition">
            Connectez-vous pour ajouter à la liste
        </a>
    {% endif %}
</div>
