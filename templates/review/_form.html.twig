<div id="review-form">
    {% if review %}
        <div class="text-white bg-gray-800 p-8 rounded-lg text-center">
            <div class="text-4xl mb-4">{{ review.review ? '👍' : '👎' }}</div>
            <p class="text-lg font-semibold mb-2">Vous avez déjà noté ce jeu</p>
            {% if review.comment %}
                <p class="text-gray-400 italic">"{{ review.comment }}"</p>
            {% endif %}
            <p class="text-sm text-gray-500 mt-3">Votre avis : <span class="font-bold {{ review.review ? 'text-green-400' : 'text-red-400' }}">{{ review.review ? 'Recommandé' : 'Non recommandé' }}</span></p>
        </div>
    {% else %}
        <form method="post" action="{{ path('app_review_form', { id: gameId }) }}" class="text-white bg-gray-800 p-8 rounded-lg">
            <h3 class="text-xl font-bold mb-4">Écrire un avis</h3>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-400 mb-2">Votre recommandation</label>
                <div class="flex gap-4">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="review[review]" value="1" class="text-green-500">
                        <span class="text-green-400 font-semibold">👍 Recommandé</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="review[review]" value="0" class="text-red-500">
                        <span class="text-red-400 font-semibold">👎 Non recommandé</span>
                    </label>
                </div>
            </div>
            <div class="mb-4">
                <label for="review_comment" class="block text-sm font-medium text-gray-400 mb-2">Commentaire (optionnel)</label>
                <textarea id="review_comment" name="review[comment]" rows="3" class="w-full bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-blue-500" placeholder="Partagez votre avis..."></textarea>
            </div>
            <input type="hidden" name="_token" value="{{ csrf_token('review' ~ gameId) }}">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition">
                Soumettre l'avis
            </button>
        </form>
    {% endif %}
</div>
